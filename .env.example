# ============================================================
# GHP IT Hub — Environment Variables (example)
# Copy to .env and adjust before running docker compose.
# ============================================================

# ---- Django ----
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Comma-separated origins allowed to call the API (frontend dev server, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Database (PostgreSQL) ----
POSTGRES_DB=ghp_it_hub
POSTGRES_USER=ghp
POSTGRES_PASSWORD=ghp_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- JWT ----
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ---- Notifications ----
NOTIFICATION_LEAD_DAYS=30

# ---- LDAP / Active Directory (optional, Phase 1 stub) ----
# Leave LDAP_ENABLED=False to use local JWT auth only.
LDAP_ENABLED=False
LDAP_SERVER_URI=ldap://dc.example.local
LDAP_BIND_DN=CN=svc-ghp,OU=Service Accounts,DC=example,DC=local
LDAP_BIND_PASSWORD=change-me
LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=local
LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=example,DC=local
